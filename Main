    "import numpy as np\n",
    "mean = np.mean(X_raw, axis=(0,1)) #this calculates the mean and makes sure only the sample and timesteps are used for the calculation\n",
    "std= np.std(X_raw, axis=(0, 1)) # this calculates the standard deviation for each sensor \n",
    "\n",
    "X_raw_normalised= (X_raw - mean)/ (std + 1e-8) # this normalizes the whole sample so It measures in 'standard deviations from the mean' and not in physical units\n",
    "print(f\"X_raw normalised's shape is {X_raw_normalised.shape} \")"
